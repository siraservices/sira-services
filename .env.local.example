# Convex
NEXT_PUBLIC_CONVEX_URL=your_convex_deployment_url

# WorkOS Authentication
# Get these from your WorkOS Dashboard: https://dashboard.workos.com
WORKOS_CLIENT_ID=client_xxxxx
WORKOS_API_KEY=sk_xxxxx

# The URL where users will be redirected after authentication
# For local development: http://localhost:3000/callback
# For production: https://yourdomain.com/callback
WORKOS_REDIRECT_URI=http://localhost:3000/callback

# A random string used to encrypt the session cookie (min 32 characters)
# Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=your_32_character_or_longer_secret_key
