# Convex
NEXT_PUBLIC_CONVEX_URL=your_convex_deployment_url

# WorkOS Authentication
# Get these from your WorkOS Dashboard: https://dashboard.workos.com
WORKOS_CLIENT_ID=client_xxxxxxxxxxxxx
WORKOS_API_KEY=sk_test_xxxxxxxxxxxxx
WORKOS_COOKIE_PASSWORD=a_32_character_or_longer_random_password_here

# Redirect URI (must be configured in WorkOS Dashboard)
# Development: http://localhost:3000/api/auth/callback
# Production: https://yourdomain.com/api/auth/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
